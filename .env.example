# --- Airtable (required) ---
AIRTABLE_PAT=pat_xxxxxxxxxxxxxxxx            # scoped PAT: data.records:read/write, schema.bases:read (+ webhook:manage if using Airtable webhooks)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# --- Internal (required) ---
INTERNAL_JOB_SECRET=change-me-32-chars-minimum    # protects /jobs/* endpoints (Bearer header or ?token= for Vercel Cron)

# --- Stripe (reference connector) ---
STRIPE_API_KEY=rk_test_xxx                   # use a RESTRICTED key scoped to what you touch
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Airtable webhooks (Pattern C, optional) ---
# Comma-separated webhook IDs to refresh daily (they expire after 7 days)
AIRTABLE_WEBHOOK_IDS=

# --- OAuth providers (optional; per provider) ---
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# GHL_CLIENT_ID=
# GHL_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000   # public base URL for /oauth/:provider/callback

NODE_ENV=development
