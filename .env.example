# --- Airtable (required) ---
AIRTABLE_PAT=pat_xxxxxxxxxxxxxxxx            # scoped PAT: data.records:read/write, schema.bases:read (+ webhook:manage if using Airtable webhooks)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# --- Internal (required) ---
INTERNAL_JOB_SECRET=change-me-32-chars-minimum    # protects /jobs/* endpoints (Bearer header or ?token= for Vercel Cron)

# --- Stripe (reference connector) ---
STRIPE_API_KEY=rk_test_xxx                   # use a RESTRICTED key scoped to what you touch
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Shopify (Partner Dashboard app — legacy static-token custom apps are
# closed to new creation as of Jan 1 2026, so this is a real OAuth app) ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_APP_CLIENT_ID=xxx                     # Partner Dashboard > your app > Client credentials
SHOPIFY_APP_CLIENT_SECRET=xxx
SHOPIFY_API_VERSION=2026-04
SHOPIFY_WEBHOOK_SECRET=whsec_xxx              # separate from the OAuth client secret — for webhook HMAC verification
# After deploying, set in the Partner Dashboard:
#   App URL:       https://<your-app>/oauth/shopify/start
#   Redirect URLs: https://<your-app>/oauth/shopify/callback
# Then visit /oauth/shopify/start?shop=your-store.myshopify.com once to install.

# --- ShipStation (V2 API) ---
SHIPSTATION_API_KEY=xxx
# Set this exact value as a custom header (key: X-Webhook-Secret) when you
# register the webhook via POST /v2/environment/webhooks — V2 has no body
# HMAC, so ShipStation just echoes back whatever custom header you configure.
SHIPSTATION_WEBHOOK_SECRET=change-me-32-chars-minimum
# Default warehouse_id (ShipStation dashboard > Settings > Warehouses), used
# only when an order's linked Vendor has no address on file.
SHIPSTATION_WAREHOUSE_ID=

# --- Airtable webhooks (Pattern C, optional) ---
# Comma-separated webhook IDs to refresh daily (they expire after 7 days)
AIRTABLE_WEBHOOK_IDS=

# --- QuickBooks Online ---
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=              # company/realm ID returned in the OAuth callback (?realmId=...)
QUICKBOOKS_ENVIRONMENT=sandbox    # "sandbox" or "production"
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN= # from QB app dashboard > Webhooks

# --- OAuth providers (optional; per provider) ---
# GHL_CLIENT_ID=
# GHL_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000   # public base URL for /oauth/:provider/callback

NODE_ENV=development
